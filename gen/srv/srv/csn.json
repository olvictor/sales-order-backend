    },
    "cds.outbox.Messages": {
      "kind": "entity",
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "timestamp": {
          "type": "cds.Timestamp"
        },
        "target": {
          "type": "cds.String"
