            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "id": {
          "key": true,
          "type": "cds.UUID"
        },
        "header": {
          "type": "cds.Association",
          "target": "sales.SalesOrderHeaders",
          "keys": [
            {
              "ref": [
                "id"
              ]
            }
          ]
        },
        "userData": {
          "type": "cds.LargeString"
        },
        "orderData": {
          "type": "cds.LargeString"
        }
      }
    },
    "sales.SalesOrderStatuses": {
      "kind": "entity",
      "elements": {
        "id": {
          "key": true,
          "type": "cds.String",
          "enum": {
            "completed": {
              "val": "COMPLETED"
            },
            "pending": {
              "val": "PENDING"
            },
            "rejected": {
              "val": "REJECTED"
            }
          }
        },
        "description": {
          "localized": true,
          "type": "cds.String"
        },
        "texts": {
          "type": "cds.Composition",
          "cardinality": {
            "max": "*"
          },
          "target": "sales.SalesOrderStatuses.texts",
          "on": [
            {
              "ref": [
                "texts",
                "id"
              ]
            },
            "=",
            {
              "ref": [
                "id"
              ]
            }
          ]
        },
        "localized": {
          "type": "cds.Association",
          "target": "sales.SalesOrderStatuses.texts",
          "on": [
            {
              "ref": [
                "localized",
                "id"
              ]
            },
            "=",
            {
              "ref": [
                "id"
              ]
            },
            "and",
            {
              "ref": [
                "localized",
                "locale"
              ]
            },
            "=",
            {
              "ref": [
                "$user",
                "locale"
              ]
            }
          ]
        }
      }
    },
    "sales.Customers": {
      "kind": "entity",
