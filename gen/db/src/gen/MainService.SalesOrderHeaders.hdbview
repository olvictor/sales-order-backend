VIEW MainService_SalesOrderHeaders AS SELECT
  SalesOrderHeaders_0.id,
  SalesOrderHeaders_0.totalAmount,
  SalesOrderHeaders_0.createdAt,
  SalesOrderHeaders_0.createdBy,
  SalesOrderHeaders_0.modifiedAt,
  SalesOrderHeaders_0.modifiedBy,
  SalesOrderHeaders_0.customer_id,
  SalesOrderHeaders_0.status_id
FROM sales_SalesOrderHeaders AS SalesOrderHeaders_0