{
    "xsappname": "sales-order-backend",
    "tenant-mode": "dedicated",
    "description": "Security profile of sales Order backend app",
    "scopes": [
        {
            "name": "uaa.user",
            "description": "UAA user"
        },
        {
            "name": "$XSAPPNAME.admin",
            "description": "Admin user"
        },
        {
            "name": "$XSAPPNAME.read_only_user",
            "description": "ReadOnly user"
        }
    ],
    "attributes": [
        {
            "name": "id",
            "description": "User id",
            "valueType": "string",
            "ValueRequired": false
        },
            {
            "name": "groups",
            "description": "User groups",
            "valueType": "string",
            "ValueRequired": false
        }
    ],
    "role-templates": [
        {
            "name": "Token_Exchange",
            "description": "UAA",
            "scope-reference": [
                "uaa.user"
            ]
        },
        {
            "name": "admin",
            "description": "Admin user",
            "attribute-references": [
                "groups",
                "id"
            ],
            "scope-reference": [
                "$XSAPPNAME.admin"
            ]
        },
        {
            "name": "read_only_user",
            "description": "ReadOnly user",
              "attribute-references": [
                "groups",
                "id"
            ],
            "scope-reference": [
                "$XSAPPNAME.read_only_user"
            ]
        }
        
    ]   
}