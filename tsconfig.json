{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "es2024",
    "module": "node16",
    "moduleResolution": "node16",
    "noImplicitAny": false,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "rootDir": "./",
    "sourceMap": true,
    "paths": {
        "@models/*" : ["./@cds-models/*/index.ts"],
        "@/*":["./srv/*"] 
    }
  },
  "include": ["srv"],
  "exclude": ["node_modules"]
}
